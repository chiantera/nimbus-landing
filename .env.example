# Copy this file to ".env" and fill in the blanks. ".env" is gitignored.
# VITE_* vars are exposed to the browser (safe: Supabase publishable keys are
# public by design). Everything else is SERVER-ONLY and must never be committed
# or prefixed with VITE_.

# --- Supabase (client-safe) ---
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxx

# --- Supabase (server only) ---
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=            # dashboard → Settings → API → service_role

# --- Stripe (server only; use TEST keys to start) ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx       # from the webhook endpoint / `stripe listen`
STRIPE_PRICE_PRO=price_xxx            # recurring Price ID for the Pro plan
APP_URL=http://localhost:5173         # post-checkout redirect base

# --- AI assistant (OpenAI-compatible: DeepSeek / Mistral / GLM) ---
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=
