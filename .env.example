# Copy this file to ".env" and fill in your provider details.
# ".env" is gitignored — your real key never gets committed.
#
# Pick ONE provider (all are OpenAI-compatible). Examples:
#
# DeepSeek:
#   AI_BASE_URL=https://api.deepseek.com/v1
#   AI_MODEL=deepseek-chat
#
# Mistral:
#   AI_BASE_URL=https://api.mistral.ai/v1
#   AI_MODEL=mistral-small-latest
#
# GLM / Zhipu (z.ai):
#   AI_BASE_URL=https://api.z.ai/api/paas/v4
#   AI_MODEL=glm-4-flash

AI_BASE_URL=
AI_API_KEY=
AI_MODEL=
